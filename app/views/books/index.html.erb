<h1> Books</h1>
  <table class="book-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Body</th>
      </tr>
    </thead>
  
  <tbody>
    <% @books.each do|book| %>
      <tr>      
        <td> <%= book.title %></td>
        <td> <%= book.body %></td>
        <td> <%= link_to "Show", book_path(book.id) %> </td>
        <td><%= link_to "Edit", edit_book_path(book) %></td>
        <td><%= link_to "Destroy", book_path(book), data: { turbo_method: :delete, turbo_confirm: "Are you sure ?" } %></td>
      </tr>
    <% end %>
    
  </tbody>

  </table>
<h1>New Book</h1>
<% if @book.errors.any? %>
 <%= @book.errors.count %> errors prohibited this book from being saved:
 <ul>
  <% @book.errors.full_messages.each do |message| %>
  <li><%= message %></li>
  <% end %>
 </ul>
 <% end%>

<%= form_with model: @book do |f| %>
  <p> Title </p>
  <%= f.text_field :title %>

  <p> Body</p>
  <%= f.text_area :body %>
  
<div class="form-actions">
  <%= f.submit 'Create Book' %>
</div>
<% end %>